# Nota: GitHub Pages no processa directives Apache.
# Aquestes regles s'activen en servidors Apache o Nginx compatible.
# Per a Cloudflare Pages, useu el fitxer _headers.

# ── Seguretat HTTP Headers ────────────────────────────────────────────────────
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
  Header set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
  Header set Content-Security-Policy "default-src 'self'; script-src 'self' https://gc.zgo.at https://js.stripe.com; style-src 'self' https://fonts.googleapis.com 'unsafe-inline'; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://malditasmaquinas.goatcounter.com https://malditasmaquinas.com; frame-src https://js.stripe.com https://hooks.stripe.com"
</IfModule>

# ── Compressió ────────────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/json font/woff2
</IfModule>

# ── Cache ─────────────────────────────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType image/png  "access plus 1 year"
  ExpiresByType image/gif  "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType text/css   "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
</IfModule>

# ── Errors ────────────────────────────────────────────────────────────────────
ErrorDocument 404 /ca/404.html
